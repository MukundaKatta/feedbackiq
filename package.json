{
  "name": "feedbackiq",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "turbo db:migrate --filter=@feedbackiq/supabase",
    "collect": "turbo collect --filter=@feedbackiq/collectors",
    "analyze": "turbo analyze --filter=@feedbackiq/analyzer"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
