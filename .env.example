# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Places
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Yelp Fusion
YELP_API_KEY=your-yelp-api-key

# G2
G2_API_TOKEN=your-g2-api-token

# App Store Connect
APP_STORE_KEY_ID=your-key-id
APP_STORE_ISSUER_ID=your-issuer-id
APP_STORE_PRIVATE_KEY=your-private-key

# Zendesk
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email
ZENDESK_API_TOKEN=your-api-token

# Intercom
INTERCOM_ACCESS_TOKEN=your-intercom-token

# Typeform
TYPEFORM_WEBHOOK_SECRET=your-webhook-secret

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
